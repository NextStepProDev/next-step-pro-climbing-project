# Database
POSTGRES_DB=nextsteppro
POSTGRES_USER=nextsteppro
POSTGRES_PASSWORD=your_secure_password_here

# Mail (SMTP)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_email_password

# OAuth2 - Google
OAUTH2_GOOGLE_CLIENT_ID=your_google_client_id
OAUTH2_GOOGLE_CLIENT_SECRET=your_google_client_secret

# Admin
ADMIN_EMAIL=admin@nextsteppro.pl

# JWT
JWT_SECRET=DockerSecretStrongKeyForJWTTokenGenerationMustBeAtLeast256BitsLong

# GHCR (GitHub Container Registry)
GHCR_OWNER=your_github_username_or_org

# Deployment
VERSION=latest

# Application (optional overrides — defaults are fine for production)
# CORS_ORIGINS is hardcoded in docker-compose.prod.yml; override here only for staging
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# SWAGGER_ENABLED=false
# LOG_LEVEL=INFO
